{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-vs-release",
      "displayName": "Windows Visual Studio 2022 Release",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build",
      "architecture": "x64"
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Windows MSVC Release (Ninja)",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    },
    {
      "name": "windows-ninja-msvc",
      "displayName": "Windows Ninja MSVC",
      "inherits": "default",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vs-release",
      "configurePreset": "windows-vs-release"
    },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc-release"
    },
    {
      "name": "windows-ninja-msvc",
      "configurePreset": "windows-ninja-msvc"
    }
  ]
}
